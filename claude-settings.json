{
  "permissions": {
    "allow": [
      "Bash(bun run check:*)",
      "Bash(bun run format)",
      "Bash(bun run check)",
      "Bash(bun run db:generate)",
      "Bash(npm run build:*)",
      "Bash(npx tsc:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run format:*)"
    ],
    "deny": [],
    "ask": [],
